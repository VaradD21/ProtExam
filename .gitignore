!backend/uploads/audio/.gitkeep
!backend/uploads/code/.gitkeep
!backend/uploads/documents/.gitkeep
!backend/uploads/images/.gitkeep
!backend/uploads/videos/.gitkeep
!backend/uploads/temp/.gitkeep

